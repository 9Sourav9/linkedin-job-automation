# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/job_automation

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Storage
STORAGE_PATH=./storage

# App
APP_ENV=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Scraper (optional — rotate user agents, add delays)
SCRAPER_HEADLESS=true
SCRAPER_DELAY_MIN=2
SCRAPER_DELAY_MAX=5

# LinkedIn Credentials
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Google API (path to credentials JSON downloaded from Google Cloud Console)
GOOGLE_CREDENTIALS_PATH=credentials/google_credentials.json

# Job Search Filters
JOB_KEYWORDS=Software Engineer,Python Developer
JOB_LOCATION=San Francisco, CA
JOB_DATE_FILTER=r86400        # r86400=24h, r604800=1week, r2592000=1month
JOB_TYPE=F                    # F=Full-time, P=Part-time, C=Contract, T=Temporary
JOB_EXPERIENCE=2,3            # 1=Internship,2=Entry,3=Associate,4=Mid-Senior,5=Director,6=Executive
JOB_REMOTE=2                  # 1=On-site, 2=Remote, 3=Hybrid
MAX_JOBS_TO_APPLY=10          # Max jobs to apply per run

# Resume Settings
BASE_RESUME_PATH=resumes/base_resume.docx
YOUR_NAME=John Doe
YOUR_EMAIL=john@example.com
YOUR_PHONE=+1-555-000-0000
YOUR_LOCATION=San Francisco, CA
YOUR_LINKEDIN=https://linkedin.com/in/johndoe
